  "keyFeatures": [
    "Cross-platform desktop app (macOS/Windows) with Tauri",
    "Multi-provider AI support (Claude, Google, OpenAI, Groq, OpenRouter, Ollama)",
    "Multi-user authentication with JWT and role-based access control",
    "Telegram bot integration with long polling",
    "OpenClaw-style skill system with on-demand loading",
    "Hybrid vision pipeline with preprocessing",
    "Audio transcription and meeting notes with faster-whisper",
    "RAG/Learning system with Ollama embeddings",
    "Reminders and cron scheduling with Pingram voice calls",
    "Spotify integration with OAuth and device control",
    "Google Workspace integration (Gmail, Calendar, Drive via gog CLI)",
    "Subagent orchestration for background tasks",
    "Reasoning controls with streaming support",
    "Global shortcut (Alt+Space) for desktop app toggle"
  ],
